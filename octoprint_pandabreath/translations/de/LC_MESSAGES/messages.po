msgid "Status"
msgstr "Status"

#: octoprint_pandabreath/templates/pandabreath_tab.jinja2:352
msgid "Stop drying"
msgstr "Trocknung stoppen"

#: octoprint_pandabreath/templates/pandabreath_tab.jinja2:295
msgid "Stop the current drying cycle to change preset or values."
msgstr ""
"Stoppen Sie den laufenden Trocknungszyklus, um Voreinstellung oder Werte zu "
"ändern."

#: octoprint_pandabreath/templates/pandabreath_tab.jinja2:292
msgid "Switch to Dry mode in the Chamber tab to edit these values."
msgstr ""
"Wechseln Sie im Kammer-Tab in den Trocken-Modus, um diese Werte zu "
"bearbeiten."

#: octoprint_pandabreath/templates/pandabreath_tab.jinja2:255
msgid ""
"Switches the device power off and engages the safety lock — even in observe-"
"only mode. The Panda Breath firmware stops any running dry cycle on its own."
msgstr ""
"Schaltet die Geräteleistung aus und aktiviert die Sicherheitsverriegelung — "
"auch im Nur-Beobachten-Modus. Die Panda-Breath-Firmware stoppt einen "
"laufenden Trocknungszyklus von selbst."

#: octoprint_pandabreath/templates/pandabreath_settings.jinja2:90
msgid "TLS"
msgstr "TLS"

#: octoprint_pandabreath/templates/pandabreath_sidebar.jinja2:56
#: octoprint_pandabreath/templates/pandabreath_sidebar.jinja2:79
