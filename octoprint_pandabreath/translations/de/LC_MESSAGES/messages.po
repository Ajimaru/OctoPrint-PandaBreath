#: octoprint_pandabreath/templates/pandabreath_tab.jinja2:121
msgid "See BIQU documentation"
msgstr "BIQU-Dokumentation ansehen"

#: octoprint_pandabreath/templates/pandabreath_tab.jinja2:321
msgid "Sends target + timer + commit in one transaction (single reconnect)."
